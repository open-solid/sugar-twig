{#
    Scroll Area component - shadcn/ui port

    Usage:
        <ScrollArea className="h-72 w-48 rounded-md border">
            <div class="p-4">Long content here...</div>
        </ScrollArea>

    Parameters:
        orientation - vertical|horizontal|both (default: 'vertical')
        className   - Additional CSS classes
#}
{%- set component = html_cva(
    base: 'relative',
    variants: {
        orientation: {
            vertical: 'overflow-y-auto overflow-x-hidden',
            horizontal: 'overflow-x-auto overflow-y-hidden',
            both: 'overflow-auto',
        },
    },
    defaultVariant: { orientation: 'vertical' },
) -%}

<div {{ html_attrs({class: component.apply({orientation: orientation|default(null)})}, exclude=['orientation']) }}>
    {%- block content %}{% endblock -%}
</div>
