{#
    Avatar component - shadcn/ui port

    Usage:
        <Avatar src="/img/avatar.jpg" alt="John Doe" />
        <Avatar fallback="CN" />
        <Avatar fallback="JD" size="lg" />

    Parameters:
        src      - Image source URL
        alt      - Image alt text
        fallback - Fallback text (e.g. initials "CN")
        size     - sm|default|lg (default: 'default')
        class    - Additional CSS classes
#}
{%- set avatar = html_cva(
    base: 'relative flex shrink-0 overflow-hidden rounded-full',
    variants: {
        size: {
            sm: 'size-8',
            default: 'size-10',
            lg: 'size-12',
        },
    },
    defaultVariant: {
        size: 'default',
    },
) -%}

<span class="{{ avatar.apply({size: size|default(null)}, class|default(null))|tailwind_merge }}" {{ html_attrs(exclude=['alt', 'size', 'src']) }}>
    {%- if src is defined -%}
    <img class="aspect-square h-full w-full" src="{{ src }}" alt="{{ alt|default('') }}" />
    {%- else -%}
    <span class="flex h-full w-full items-center justify-center rounded-full bg-muted text-sm font-medium">
        {{ fallback|default('?') }}
    </span>
    {%- endif -%}
</span>
