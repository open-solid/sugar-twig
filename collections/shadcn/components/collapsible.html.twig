{#
    Collapsible component - shadcn/ui port (Alpine.js)

    Usage:
        <Collapsible>
            <BlockTrigger><button class="text-sm font-semibold">Toggle details</button></BlockTrigger>
            <BlockBody><p class="text-sm text-muted-foreground py-2">Hidden details content here.</p></BlockBody>
        </Collapsible>

    Parameters:
        open  - Initial open state (default: false)
        class - Additional CSS classes
#}
{%- set open = open|default(false) -%}

<div x-data="{ open: {{ open ? 'true' : 'false' }} }" class="{{ class|default('') }}" {{ html_attrs(exclude=['open']) }}>
    <div @click="open = !open" class="cursor-pointer">
        {% block trigger %}{% endblock %}
    </div>
    <div x-show="open" x-collapse x-cloak>
        {% block body %}{% endblock %}
    </div>
</div>
