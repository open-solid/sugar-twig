{#
    Input Group component - shadcn/ui port
    Wraps an input with prefix/suffix elements.

    Usage:
        <InputGroup>
            <BlockPrefix><svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></BlockPrefix>
            <Input placeholder="Search..." class="pl-9" />
        </InputGroup>

    Parameters:
        className - Additional CSS classes
#}
<div {{ html_attrs({class: 'relative'}) }}>
    {% set prefix_content %}{% block prefix %}{% endblock %}{% endset %}
    {% if prefix_content|trim is not empty %}
    <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-muted-foreground">
        {{ prefix_content|raw }}
    </div>
    {% endif %}
    {% block content %}{% endblock %}
    {% set suffix_content %}{% block suffix %}{% endblock %}{% endset %}
    {% if suffix_content|trim is not empty %}
    <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3 text-muted-foreground">
        {{ suffix_content|raw }}
    </div>
    {% endif %}
</div>
