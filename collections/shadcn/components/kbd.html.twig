{#
    Kbd (keyboard shortcut) component - shadcn/ui port

    Usage:
        <Kbd>⌘K</Kbd>
        <Kbd>Ctrl+S</Kbd>

    Parameters:
        className - Additional CSS classes
#}
<kbd {{ html_attrs({class: 'pointer-events-none inline-flex h-5 select-none items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium text-muted-foreground'}) }}>
    {%- block content %}{% endblock -%}
</kbd>
