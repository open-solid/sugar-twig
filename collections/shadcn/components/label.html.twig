{#
    Label component - shadcn/ui port

    Usage:
        <Label for="email" content="Email" />

    Parameters:
        for     - ID of the associated form element
        content - Label text
        className - Additional CSS classes
#}
<label{% if for is defined %} for="{{ for }}"{% endif %} {{ html_attrs({class: 'text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70'}, exclude=['content', 'for']) }}>
    {{- content|default('')|raw -}}
</label>
