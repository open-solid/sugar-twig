{#
    Toggle Group component - shadcn/ui port (Alpine.js)

    Usage:
        <ToggleGroup type="single" items="{{ [
            { value: 'bold', content: '<b>B</b>' },
            { value: 'italic', content: '<i>I</i>' },
            { value: 'underline', content: '<u>U</u>' },
        ] }}" />

    Parameters:
        type      - single|multiple (default: 'single')
        items     - Array of {value, content, pressed?}
        variant   - default|outline (default: 'default')
        size      - default|sm|lg (default: 'default')
        className - Additional CSS classes
#}
{%- set type = type|default('single') -%}

{%- set component = html_cva(
    base: "inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium transition-colors hover:bg-muted hover:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50",
    variants: {
        variant: {
            default: '',
            outline: 'border border-input bg-transparent shadow-xs hover:bg-accent hover:text-accent-foreground',
        },
        size: {
            default: 'h-9 px-3',
            sm: 'h-8 px-2',
            lg: 'h-10 px-3',
        },
    },
    defaultVariant: { variant: 'default', size: 'default' },
) -%}

<div
    role="group"
    x-data="{ selected: {% if type == 'single' %}''{% else %}[]{% endif %} }"
    {{ html_attrs({class: 'inline-flex items-center justify-center gap-1'}, exclude=['size', 'type', 'variant']) }}
>
    {%- for item in items|default([]) -%}
    <button
        type="button"
        @click="{% if type == 'single' %}selected = selected === '{{ item.value }}' ? '' : '{{ item.value }}'{% else %}selected.includes('{{ item.value }}') ? selected = selected.filter(v => v !== '{{ item.value }}') : selected.push('{{ item.value }}'){% endif %}"
        :aria-pressed="{% if type == 'single' %}selected === '{{ item.value }}'{% else %}selected.includes('{{ item.value }}'){% endif %}"
        :class="{% if type == 'single' %}selected === '{{ item.value }}'{% else %}selected.includes('{{ item.value }}'){% endif %} ? 'bg-accent text-accent-foreground' : ''"
        class="{{ component.apply({variant: variant|default(null), size: size|default(null)}) }}"
    >
        {{ item.content|raw }}
    </button>
    {%- endfor -%}
</div>
