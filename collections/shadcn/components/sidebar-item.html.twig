{#
    Sidebar Item component - shadcn/ui port

    Usage:
        <SidebarItem href="/dashboard" content="Dashboard" active />
        <SidebarItem href="/settings" content="Settings" />

    Parameters:
        href    - Link URL
        icon    - Icon SVG HTML
        content - Item label
        active  - Whether currently active (default: false)
        class   - Additional CSS classes
#}
{%- set active = active|default(false) -%}

{%- set component = html_cva(
    base: "flex items-center gap-3 rounded-lg px-3 py-2 text-sm transition-colors",
    variants: {
        active: {
            'true': 'bg-sidebar-accent text-sidebar-accent-foreground font-medium',
            'false': 'text-sidebar-foreground/70 hover:bg-sidebar-accent hover:text-sidebar-accent-foreground',
        },
    },
    defaultVariant: { active: 'false' },
) -%}

<a
    {% if href is defined %}href="{{ href }}"{% endif %}
    class="{{ component.apply({active: active ? 'true' : 'false'}, class|default(null))|tailwind_merge }}"
    {{ html_attrs(exclude=['content', 'href']) }}
>
    {%- if icon is defined -%}
    <span class="size-4 shrink-0">{{ icon|raw }}</span>
    {%- endif -%}
    {{- content|default('')|raw -}}
</a>
