{#
    Slider component - shadcn/ui port

    Usage:
        <Slider name="volume" value="50" />
        <Slider name="price" min="0" max="500" step="10" value="200" />

    Parameters:
        name  - Input name
        id    - Input id
        value - Current value (default: 50)
        min   - Minimum value (default: 0)
        max   - Maximum value (default: 100)
        step  - Step increment (default: 1)
        class - Additional CSS classes
#}
{%- set value = value|default(50) -%}
{%- set min = min|default(0) -%}
{%- set max = max|default(100) -%}
{%- set step = step|default(1) -%}

<input
    type="range"
    {% if name is defined %}name="{{ name }}"{% endif %}
    {% if id is defined %}id="{{ id }}"{% endif %}
    value="{{ value }}"
    min="{{ min }}"
    max="{{ max }}"
    step="{{ step }}"
    class="w-full h-2 cursor-pointer appearance-none rounded-full bg-primary/20 accent-primary focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 {{ class|default('') }}"
    {{ html_attrs(exclude=['id', 'max', 'min', 'name', 'step', 'value']) }}
/>
