{#
    Separator component - shadcn/ui port

    Usage:
        <Separator />
        <Separator orientation="vertical" className="h-6" />

    Parameters:
        orientation - horizontal|vertical (default: 'horizontal')
        className   - Additional CSS classes
#}
{%- set orientation = orientation|default('horizontal') -%}

{%- if orientation == 'horizontal' -%}
<div role="separator" {{ html_attrs({class: 'shrink-0 bg-border h-px w-full'}, exclude=['orientation']) }}></div>
{%- else -%}
<div role="separator" {{ html_attrs({class: 'shrink-0 bg-border w-px h-full'}, exclude=['orientation']) }}></div>
{%- endif -%}
