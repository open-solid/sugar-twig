{#
    Badge component - shadcn/ui port

    Usage:
        <Badge>New</Badge>
        <Badge variant="destructive">Expired</Badge>
        <Badge variant="outline">Draft</Badge>

    Parameters:
        variant   - default|secondary|destructive|outline (default: 'default')
        className - Additional CSS classes
#}
{%- set badge = html_cva(
    base: 'inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2',
    variants: {
        variant: {
            default: 'border-transparent bg-primary text-primary-foreground shadow-xs hover:bg-primary/80',
            secondary: 'border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80',
            destructive: 'border-transparent bg-destructive text-white shadow-xs hover:bg-destructive/80',
            outline: 'text-foreground',
        },
    },
    defaultVariant: {
        variant: 'default',
    },
) -%}

<span {{ html_attrs({class: badge.apply({variant: variant|default(null)})}, exclude=['variant']) }}>
    {%- block content %}{% endblock -%}
</span>
