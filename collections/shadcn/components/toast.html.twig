{#
    Toast container component - shadcn/ui port (Alpine.js)
    Place this once in your base layout. Dispatching toasts is done via Alpine.js events.

    Usage:
        In base.html.twig: <Toast />
        In any component:  @click="$dispatch('toast', { title: 'Saved!', description: 'Your changes...' })"
        With variant:      @click="$dispatch('toast', { title: 'Error', variant: 'destructive' })"

    Parameters:
        position  - top-right|top-left|bottom-right|bottom-left (default: 'bottom-right')
        className - Additional CSS classes
#}
{%- set container = html_cva(
    base: 'fixed z-[100] flex max-h-screen w-full flex-col-reverse p-4 sm:flex-col sm:max-w-[420px]',
    variants: {
        position: {
            'top-right': 'top-0 right-0',
            'top-left': 'top-0 left-0',
            'bottom-right': 'bottom-0 right-0',
            'bottom-left': 'bottom-0 left-0',
        },
    },
    defaultVariant: { position: 'bottom-right' },
) -%}

<div
    {{ html_attrs({class: container.apply({position: position|default(null)})}, exclude=['position']) }}
    x-data="{
        toasts: [],
        add(detail) {
            const id = Date.now();
            this.toasts.push({ id, ...detail });
            setTimeout(() => this.remove(id), detail.duration || 5000);
        },
        remove(id) {
            this.toasts = this.toasts.filter(t => t.id !== id);
        }
    }"
    @toast.window="add($event.detail)"
>
    <template x-for="toast in toasts" :key="toast.id">
        <div
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-2 sm:translate-x-2 sm:translate-y-0"
            x-transition:enter-end="opacity-100 translate-y-0 sm:translate-x-0"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            :class="toast.variant === 'destructive' ? 'border-destructive bg-destructive text-white' : 'border bg-background text-foreground'"
            class="group pointer-events-auto relative flex w-full items-center justify-between space-x-2 overflow-hidden rounded-md p-4 shadow-lg mb-2"
        >
            <div class="grid gap-1">
                <div class="text-sm font-semibold" x-text="toast.title"></div>
                <template x-if="toast.description">
                    <div class="text-sm opacity-90" x-text="toast.description"></div>
                </template>
            </div>
            <button
                @click="remove(toast.id)"
                class="absolute right-1 top-1 rounded-md p-1 text-foreground/50 opacity-0 transition-opacity hover:text-foreground group-hover:opacity-100"
            >
                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>
        </div>
    </template>
</div>
