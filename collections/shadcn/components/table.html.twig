{#
    Table component - shadcn/ui port

    Usage:
        <Table>
            <thead>
                <tr class="border-b">
                    <TableHeader>Name</TableHeader>
                    <TableHeader>Status</TableHeader>
                </tr>
            </thead>
            <tbody>
                <TableRow>
                    <TableCell>Grand Floridian</TableCell>
                    <TableCell>Active</TableCell>
                </TableRow>
            </tbody>
        </Table>

    Parameters:
        className - Additional CSS classes
#}
<div class="relative w-full overflow-auto">
    <table {{ html_attrs({class: 'w-full caption-bottom text-sm'}) }}>
        {%- block content %}{% endblock -%}
    </table>
</div>
