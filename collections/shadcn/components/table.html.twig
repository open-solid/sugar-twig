{#
    Table component - shadcn/ui port

    Usage:
        <Table>
            <thead>
                <tr class="border-b">
                    <TableHeader content="Name" />
                    <TableHeader content="Status" />
                </tr>
            </thead>
            <tbody>
                <TableRow>
                    <TableCell content="Grand Floridian" />
                    <TableCell content="Active" />
                </TableRow>
            </tbody>
        </Table>

    Parameters:
        className - Additional CSS classes
#}
<div class="relative w-full overflow-auto">
    <table {{ html_attrs({class: 'w-full caption-bottom text-sm'}) }}>
        {%- block content %}{% endblock -%}
    </table>
</div>
