{#
Spinner component - shadcn/ui port

Usage:
    <Spinner />
    <Spinner size="lg" />

Parameters:
    size  - default|md|lg (default: 'default')
    class - Additional CSS classes
#}
{%- set spinner = html_cva(
    base: 'animate-spin',
    variants: {
        size: {
            default: 'size-4',
            md: 'size-6',
            lg: 'size-8',
        },
    },
    defaultVariant: {
        size: 'default',
    },
) -%}

<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
     class="{{ spinner.apply({size: size|default(null)}, class|default(null))|tailwind_merge }}" role="status" aria-label="Loading"
     data-icon="inline-start"
    {{ html_attrs(exclude=['size']) }}>
    <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
</svg>
