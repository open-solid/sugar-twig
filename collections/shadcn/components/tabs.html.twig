{#
    Tabs component - shadcn/ui port (Alpine.js)

    Usage:
        <Tabs tabs="{{ [
            { value: 'account', label: 'Account' },
            { value: 'password', label: 'Password' },
        ] }}">
            <TabsContent value="account">
                <p>Account settings here.</p>
            </TabsContent>
            <TabsContent value="password">
                <p>Change password here.</p>
            </TabsContent>
        </Tabs>

    Parameters:
        tabs    - Array of {value, label}
        default - Default active tab value (defaults to first tab)
        className - Additional CSS classes
#}
{%- set default_tab = default|default(tabs[0].value) -%}

<div x-data="{ tab: '{{ default_tab }}' }" {{ html_attrs(exclude=['default', 'tabs']) }}>
    <div class="inline-flex h-9 items-center justify-center rounded-lg bg-muted p-1 text-muted-foreground" role="tablist">
        {%- for t in tabs -%}
        <button
            type="button"
            @click="tab = '{{ t.value }}'"
            :class="tab === '{{ t.value }}' ? 'bg-background text-foreground shadow' : ''"
            class="inline-flex items-center justify-center whitespace-nowrap rounded-md px-3 py-1 text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50"
            role="tab"
            :aria-selected="(tab === '{{ t.value }}').toString()"
        >
            {{ t.label }}
        </button>
        {%- endfor -%}
    </div>
    {% block content %}{% endblock %}
</div>
