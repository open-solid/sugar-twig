{#
    Native Select component - shadcn/ui port

    Usage:
        <NativeSelect name="fruit" placeholder="Select a fruit..." options="{{ [
            { value: 'apple', label: 'Apple' },
            { value: 'banana', label: 'Banana' },
            { value: 'cherry', label: 'Cherry' },
        ] }}" />

    Parameters:
        name        - Select name
        id          - Select id
        placeholder - Placeholder option text
        options     - Array of {value, label, selected?}
        className   - Additional CSS classes
#}
<select
    {% if name is defined %}name="{{ name }}"{% endif %}
    {% if id is defined %}id="{{ id }}"{% endif %}
    {{ html_attrs({class: 'flex h-9 w-full items-center justify-between rounded-md border border-input bg-transparent px-3 py-2 text-sm shadow-xs ring-offset-background placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-ring disabled:cursor-not-allowed disabled:opacity-50'}, exclude=['id', 'name', 'placeholder']) }}
>
    {%- if placeholder is defined -%}
    <option value="" disabled selected>{{ placeholder }}</option>
    {%- endif -%}
    {%- for option in options|default([]) -%}
    <option value="{{ option.value }}"{% if option.selected|default(false) %} selected{% endif %}>{{ option.label }}</option>
    {%- endfor -%}
</select>
