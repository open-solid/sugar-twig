{#
    Table Header Cell component - shadcn/ui port

    Usage:
        <TableHeader>Name</TableHeader>

    Parameters:
        className - Additional CSS classes
#}
<th {{ html_attrs({class: 'h-10 px-2 text-left align-middle font-medium text-muted-foreground [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px]'}) }}>
    {%- block content %}{% endblock -%}
</th>
