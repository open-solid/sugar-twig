{
    "name": "open-solid/sugar-twig",
    "type": "symfony-bundle",
    "license": "MIT",
    "description": "Syntactic sugar for Twig templates",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "symfony/twig-bundle": "^6.4|^7.4|^8.0",
        "tales-from-a-dev/twig-tailwind-extra": "^1.1",
        "twig/extra-bundle": "^3.24",
        "twig/html-extra": "^3.24"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "OpenSolid\\SugarTwig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenSolid\\SugarTwig\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
