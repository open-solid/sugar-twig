{
    "name": "open-solid/sugar-twig",
    "type": "symfony-bundle",
    "license": "MIT",
    "description": "Syntactic sugar for Twig templates",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.4",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "OpenSolid\\SugarTwig\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenSolid\\SugarTwig\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
